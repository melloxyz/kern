---
import Base from '../layouts/Base.astro';
import { getPublishedPosts, getReadingTime, CATEGORIES } from '../utils/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();

  return CATEGORIES.map(route => ({
    params: { category: route.slug },
    props: {
      label: route.label,
      posts: posts.filter(post => post.data.category === route.category),
    },
  }));
}

const { label, posts } = Astro.props;

function formatDate(date: Date) {
  return date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' });
}
---

<Base title={label} description={`Posts em ${label} no KERN`}>
  <div class="feed">
    <div class="tag-header">
      <a href="/" class="post__back">← voltar ao feed</a>
      <h1>
        {label}
        <small style="font-weight:400;font-size:0.6em;color:var(--ink-light);">
          ({posts.length} post{posts.length !== 1 ? 's' : ''})
        </small>
      </h1>
    </div>

    {posts.length === 0 ? (
      <p class="search-results__empty">Ainda não há notícias nesta categoria.</p>
    ) : (
      <div>
        {posts.map(post => (
          <a href={`/posts/${post.id}`} class="post-row">
            <div>
              <div class="post-row__meta">
                <span class="post-row__category">{post.data.category}</span>
                <span class="post-row__date">· {formatDate(post.data.date)}</span>
              </div>
              <h2 class="post-row__title">{post.data.title}</h2>
              <p class="post-row__excerpt">{post.data.excerpt}</p>
            </div>
            <span class="post-row__time">{getReadingTime(post.body || '')}</span>
          </a>
        ))}
      </div>
    )}
  </div>
</Base>
