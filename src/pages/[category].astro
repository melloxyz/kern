---
import Base from '../layouts/Base.astro';
import { getPublishedPosts, getReadingTime, CATEGORIES } from '../utils/posts';
import CategoryBadge from '../components/CategoryBadge.astro';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();

  return CATEGORIES.map(route => ({
    params: { category: route.slug },
    props: {
      category: route,
      posts: posts.filter(post => post.data.category === route.category),
    },
  }));
}

const { category, posts } = Astro.props;
const { label, description } = category;

function formatDate(date: Date) {
  return date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' });
}
---

<Base title={label} description={description}>
  <div class="category-hero">
    <div class="category-hero__header">
      <a href="/" class="post__back">← voltar ao feed</a>
      <div class="category-hero__meta">
        <span class="category-hero__count">{posts.length} post{posts.length !== 1 ? 's' : ''}</span>
      </div>
    </div>
    
    <h1 class="category-hero__title">{label}</h1>
    <p class="category-hero__description">{description}</p>
    <div class="category-hero__divider"></div>
  </div>

  <div class="feed">
    {posts.length === 0 ? (
      <p class="search-results__empty">Ainda não há notícias nesta categoria.</p>
    ) : (
      <div class="category-grid">
        {posts.map(post => (
          <a href={`/posts/${post.id}`} class="card">
            <div>
              <div class="card__meta">
                <CategoryBadge category={post.data.category} class="card__category" />
                <span class="card__date">{formatDate(post.data.date)}</span>
              </div>
              <h2 class="card__title">{post.data.title}</h2>
              <p class="card__excerpt">{post.data.excerpt}</p>
            </div>
            <span class="card__time">{getReadingTime(post.body || '')}</span>
          </a>
        ))}
      </div>
    )}
  </div>
</Base>
