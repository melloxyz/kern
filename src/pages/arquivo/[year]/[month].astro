---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '../../../utils/posts';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts', ({ data }) => !data.draft);
  const months = new Map();
  for (const post of allPosts) {
    const y = post.data.date.getFullYear();
    const m = post.data.date.getMonth() + 1;
    const key = `${y}-${String(m).padStart(2,'0')}`;
    if (!months.has(key)) months.set(key, { year: String(y), month: String(m).padStart(2,'0') });
  }
  return [...months.values()].map(({ year, month }) => ({
    params: { year, month },
    props: {
      year: Number(year), month: Number(month),
      posts: allPosts
        .filter(p => p.data.date.getFullYear() === Number(year) && p.data.date.getMonth() + 1 === Number(month))
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
    },
  }));
}

const { year, month, posts } = Astro.props;
const MONTHS_PT = ['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
const label = `${MONTHS_PT[month - 1]} ${year}`;

function formatDate(date: Date) {
  return date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' });
}
---

<Base title={label}>
  <div class="feed">
    <div class="tag-header">
      <a href="/" class="post__back">← feed principal</a>
      <h1>{label} <small style="font-weight:400;font-size:0.6em;color:var(--ink-light);">({posts.length} post{posts.length !== 1 ? 's' : ''})</small></h1>
    </div>
    <div>
      {posts.map(post => (
        <a href={`/posts/${post.id}`} class="post-row">
          <div>
            <div class="post-row__meta">
              <span class="post-row__category">{post.data.category}</span>
              <span class="post-row__date">· {formatDate(post.data.date)}</span>
            </div>
            <h2 class="post-row__title">{post.data.title}</h2>
            <p class="post-row__excerpt">{post.data.excerpt}</p>
          </div>
          <span class="post-row__time">{getReadingTime(post.body || '')}</span>
        </a>
      ))}
    </div>
  </div>
</Base>
