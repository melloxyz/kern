---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts', ({ data }) => !data.draft);

  const months = new Map();
  for (const post of allPosts) {
    const y = post.data.date.getFullYear();
    const m = post.data.date.getMonth() + 1;
    const key = `${y}-${String(m).padStart(2,'0')}`;
    if (!months.has(key)) months.set(key, { year: String(y), month: String(m).padStart(2,'0') });
  }

  return [...months.values()].map(({ year, month }) => ({
    params: { year, month },
    props: {
      year: Number(year),
      month: Number(month),
      posts: allPosts
        .filter(p => {
          return p.data.date.getFullYear() === Number(year) &&
                 p.data.date.getMonth() + 1 === Number(month);
        })
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
    },
  }));
}

const { year, month, posts } = Astro.props;

const MONTHS_PT = ['Janeiro','Fevereiro','Março','Abril','Maio','Junho',
                   'Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];

const label = `${MONTHS_PT[month - 1]} ${year}`;

function formatDate(date) {
  return date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' });
}

// Monta sidebar com todos os meses disponíveis
const allPostsForSidebar = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const archiveMap = new Map();
for (const post of allPostsForSidebar) {
  const y = post.data.date.getFullYear();
  const m = post.data.date.getMonth();
  const key = `${y}-${String(m).padStart(2,'0')}`;
  if (!archiveMap.has(key)) {
    archiveMap.set(key, {
      label: `${y} - ${MONTHS_PT[m]}`,
      year: y, month: m + 1,
      count: 0,
      href: `/arquivo/${y}/${String(m+1).padStart(2,'0')}`,
    });
  }
  archiveMap.get(key).count++;
}
const archive = [...archiveMap.values()];
const activeKey = `${year}-${String(month).padStart(2,'0')}`;
---

<Base title={label}>
  <div class="container">
    <div class="feed-layout">

      <div class="feed-layout__main">
        <div class="tag-header">
          <a href="/" class="post__back">← feed principal</a>
          <h1>{label} <small style="font-weight:400;font-size:0.6em;color:#888;">({posts.length} post{posts.length !== 1 ? 's' : ''})</small></h1>
        </div>

        <div>
          {posts.map(post => (
            <a
              href={`/posts/${post.slug}`}
              class={`post-row ${post.data.image ? 'post-row--has-image' : ''}`}
            >
              <div>
                <div class="post-row__meta">
                  <span class="post-row__category">{post.data.category}</span>
                  <span class="post-row__date">· {formatDate(post.data.date)}</span>
                </div>
                <h2 class="post-row__title">{post.data.title}</h2>
                <p class="post-row__excerpt">{post.data.excerpt}</p>
              </div>
              {post.data.image
                ? <img src={post.data.image} alt={post.data.title} class="post-row__thumb" loading="lazy" />
                : <span class="post-row__time">{post.data.readTime ?? '5 min'}</span>
              }
            </a>
          ))}
        </div>
      </div>

      <aside class="feed-layout__sidebar">
        <nav class="archive">
          <p class="archive__title">Nesta página</p>
          <ul class="archive__list">
            {archive.map(entry => (
              <li class={`archive__item ${activeKey === `${entry.year}-${String(entry.month).padStart(2,'0')}` ? 'archive__item--active' : ''}`}>
                <a href={entry.href}>
                  {entry.label}
                  <span class="archive__count">{entry.count}</span>
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>

    </div>
  </div>
</Base>
