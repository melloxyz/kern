---
import Base from '../../../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '../../../../utils/posts';

export async function getStaticPaths() {
  const CATEGORY_ROUTES = [
    { slug: 'modelos', category: 'MODELOS', label: 'Modelos' },
    { slug: 'seguranca', category: 'SEGURANÇA', label: 'Segurança' },
    { slug: 'open-source', category: 'OPEN SOURCE', label: 'Open Source' },
    { slug: 'trabalho', category: 'TRABALHO', label: 'Trabalho' },
    { slug: 'negocios', category: 'NEGÓCIOS', label: 'Negócios' },
    { slug: 'politica', category: 'POLÍTICA', label: 'Política' },
    { slug: 'pesquisa', category: 'PESQUISA', label: 'Pesquisa' },
  ];

  const allPosts = await getCollection('posts', ({ data }) => !data.draft);
  const paths = [];

  const archiveMap = new Map();
  for (const post of allPosts) {
    const y = post.data.date.getFullYear();
    const m = post.data.date.getMonth() + 1;
    const key = `${y}-${String(m).padStart(2,'0')}`;
    if (!archiveMap.has(key)) {
      archiveMap.set(key, { year: String(y), month: String(m).padStart(2,'0') });
    }
  }

  for (const { year, month } of archiveMap.values()) {
    for (const route of CATEGORY_ROUTES) {
      const filteredPosts = allPosts
        .filter(p => p.data.date.getFullYear() === Number(year) && p.data.date.getMonth() + 1 === Number(month) && p.data.category === route.category)
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

      paths.push({
        params: { year, month, category: route.slug },
        props: {
          year: Number(year),
          month: Number(month),
          categoryLabel: route.label,
          posts: filteredPosts,
        },
      });
    }
  }

  return paths;
}

const { year, month, categoryLabel, posts } = Astro.props;
const MONTHS_PT = ['Janeiro','Fevereiro','Março','Abril','Maio','Junho',
                   'Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
const monthLabel = `${MONTHS_PT[month - 1]} ${year}`;
const title = `${categoryLabel} em ${monthLabel}`;

function formatDate(date: Date) {
  return date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' });
}
---

<Base title={title} description={`Posts sobre ${categoryLabel} em ${monthLabel} no KERN.IA`}>
  <div class="feed">
    <div class="tag-header">
      <a href={`/arquivo/${year}/${String(month).padStart(2, '0')}`} class="post__back">← voltar para {monthLabel}</a>
      <h1>{title} <small style="font-weight:400;font-size:0.6em;color:var(--ink-light);">({posts.length} post{posts.length !== 1 ? 's' : ''})</small></h1>
    </div>
    
    {posts.length === 0 ? (
      <p class="search-results__empty">Ainda não há notícias nesta categoria para este mês.</p>
    ) : (
      <div>
        {posts.map(post => (
          <a href={`/posts/${post.slug}`} class="post-row">
            <div>
              <div class="post-row__meta">
                <span class="post-row__category">{post.data.category}</span>
                <span class="post-row__date">· {formatDate(post.data.date)}</span>
              </div>
              <h2 class="post-row__title">{post.data.title}</h2>
              <p class="post-row__excerpt">{post.data.excerpt}</p>
            </div>
            <span class="post-row__time">{getReadingTime(post.body)}</span>
          </a>
        ))}
      </div>
    )}
  </div>
</Base>