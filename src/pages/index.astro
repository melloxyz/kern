---
import Base from '../layouts/Base.astro';
import { getRecentPosts, getReadingTime } from '../utils/posts';

const allPosts = await getRecentPosts();

const featuredPosts = allPosts.filter(p => p.data.featured);
const featured = featuredPosts.slice(0, 2);
const rest = allPosts.filter(p => !featured.includes(p));

function formatDate(date: Date) {
  return date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' });
}
---

<Base>
  <div class="feed">

    {featured.length > 0 && (
      <div class={`feed__featured ${featured.length === 1 ? 'feed__featured-single' : ''}`}>
        {featured.map(post => (
          <a href={`/posts/${post.id}`} class="card">
            <div class="card__meta">
              <span class="card__category">{post.data.category}</span>
              <span class="card__date">{formatDate(post.data.date)}</span>
            </div>
            <h2 class="card__title">{post.data.title}</h2>
            <p class="card__excerpt">{post.data.excerpt}</p>
            <span class="card__read">ler → ({getReadingTime(post.body || '')})</span>
          </a>
        ))}
      </div>
    )}

    {featured.length > 0 && rest.length > 0 && (
      <div class="divider">
        <span class="divider__label">Mais recentes</span>
      </div>
    )}

    <div>
      {rest.map(post => (
        <a href={`/posts/${post.id}`} class="post-row">
          <div>
            <div class="post-row__meta">
              <span class="post-row__category">{post.data.category}</span>
              <span class="post-row__date">· {formatDate(post.data.date)}</span>
            </div>
            <h2 class="post-row__title">{post.data.title}</h2>
            <p class="post-row__excerpt">{post.data.excerpt}</p>
          </div>
          <span class="post-row__time">{getReadingTime(post.body || '')}</span>
        </a>
      ))}
    </div>

  </div>
</Base>
