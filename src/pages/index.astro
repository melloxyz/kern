---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featured = allPosts.filter(p => p.data.featured);
const rest     = allPosts.filter(p => !p.data.featured);

const MONTHS_PT = ['Janeiro','Fevereiro','Março','Abril','Maio','Junho',
                   'Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];

const archiveMap = new Map();
for (const post of allPosts) {
  const y = post.data.date.getFullYear();
  const m = post.data.date.getMonth();
  const key = `${y}-${String(m).padStart(2,'0')}`;
  if (!archiveMap.has(key)) {
    archiveMap.set(key, {
      label: `${y} - ${MONTHS_PT[m]}`,
      year: y, month: m + 1,
      count: 0,
      href: `/arquivo/${y}/${String(m+1).padStart(2,'0')}`,
    });
  }
  archiveMap.get(key).count++;
}
const archive = [...archiveMap.values()];

function formatDate(date) {
  return date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' });
}
---

<Base>
  <div class="container">
    <div class="feed-layout">

      <div class="feed-layout__main">

        {featured.length > 0 && (
          <div class={`feed__featured ${featured.length === 1 ? 'feed__featured-single' : ''}`}>
            {featured.map(post => (
              <a href={`/posts/${post.slug}`} class="card">
                <div class="card__meta">
                  <span class="card__category">{post.data.category}</span>
                  <span class="card__date">{formatDate(post.data.date)}</span>
                </div>
                <h2 class="card__title">{post.data.title}</h2>
                <p class="card__excerpt">{post.data.excerpt}</p>
                <span class="card__read">ler → ({post.data.readTime ?? '5 min'})</span>
              </a>
            ))}
          </div>
        )}

        {featured.length > 0 && rest.length > 0 && (
          <div class="divider">
            <span class="divider__label">Mais recentes</span>
          </div>
        )}

        <div>
          {rest.map(post => (
            <a
              href={`/posts/${post.slug}`}
              class="post-row"
            >
              <div>
                <div class="post-row__meta">
                  <span class="post-row__category">{post.data.category}</span>
                  <span class="post-row__date">· {formatDate(post.data.date)}</span>
                </div>
                <h2 class="post-row__title">{post.data.title}</h2>
                <p class="post-row__excerpt">{post.data.excerpt}</p>
              </div>
              <span class="post-row__time">{post.data.readTime ?? '5 min'}</span>
            </a>
          ))}
        </div>

      </div>

      <aside class="feed-layout__sidebar">
        <nav class="archive">
          <p class="archive__title">Nesta página</p>
          <ul class="archive__list">
            {archive.map(entry => (
              <li class="archive__item">
                <a href={entry.href}>
                  {entry.label}
                  <span class="archive__count">{entry.count}</span>
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>

    </div>
  </div>
</Base>
