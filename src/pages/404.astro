---
import Base from '../layouts/Base.astro';
---

<Base title="404 — Ruído Detectado" description="Página não encontrada no KERN">
  <div class="container--post">
    <div style="text-align: center; padding: 80px 0;">
      <h1 style="font-family: var(--ui); font-size: 80px; color: var(--red); margin-bottom: 20px;">404</h1>
      <p style="font-family: var(--editorial); font-size: 20px; color: var(--ink-mid); margin-bottom: 40px;">
        Ops! Detectamos um ruído inesperado. A página que você procura não existe ou foi movida.
      </p>
      <a href="/" class="post__back" style="display: inline-block; float: none;">← Voltar para o sinal principal (Home)</a>
    </div>
  </div>
</Base>