---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import ShareButtons from '../../components/ShareButtons.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import CategoryBadge from '../../components/CategoryBadge.astro';
import { getPublishedPosts, getRelatedPosts } from '../../utils/posts';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(post);
const readingTime = remarkPluginFrontmatter?.readingTime;

const allPosts = await getPublishedPosts();
const relatedPosts = getRelatedPosts(post, allPosts);

function formatDate(date: Date) {
  const time = date.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
  const day = date.toLocaleDateString('pt-BR', {
    weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'
  });
  return `${time} · ${day}`;
}
---

<Base 
  title={post.data.title} 
  description={post.data.excerpt} 
  image={post.data.image} 
  ogType="article"
  publishDate={post.data.date}
>
  <div class="container--post">
    <article class="post">

      <a href="/" class="post__back">← voltar ao feed</a>

      <div class="post__meta">
        <div class="post__meta-left">
          <CategoryBadge category={post.data.category} class="post__category" data-pagefind-filter="category" />
          <span class="post__sep">·</span>
          <span class="post__date" data-pagefind-meta="date">{formatDate(post.data.date)}</span>
          <span class="post__sep">·</span>
          <span class="post__readtime">{readingTime} de leitura</span>
        </div>

        {post.data.source && (
          <a href={post.data.source} target="_blank" rel="noopener noreferrer" class="post__source-minimal">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
              <polyline points="15 3 21 3 21 9"></polyline>
              <line x1="10" y1="14" x2="21" y2="3"></line>
            </svg>
            <span>{new URL(post.data.source).hostname.replace('www.', '')}</span>
          </a>
        )}
      </div>

      <h1 class="post__title" data-pagefind-meta="title">{post.data.title}</h1>

      {post.data.image && (
        <Image src={post.data.image} alt={post.data.title} width={1200} height={600} class="post__hero" loading="eager" />
      )}

      <div class="post__body">
        <Content />
      </div>

      <div class="post__tags-section">
        <span class="post__tags-label">Tags</span>
        <div class="post__tags">
          {post.data.tags.map(tag => (
            <a href={`/tag/${tag}`} class="post__tag">#{tag}</a>
          ))}
        </div>
      </div>

      <ShareButtons title={post.data.title} url={Astro.url.href} />
      
      <RelatedPosts posts={relatedPosts} />

    </article>
  </div>
</Base>
