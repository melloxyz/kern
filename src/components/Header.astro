---
---
<header class="site-header">
  <div class="site-header__inner">
    
    <button id="mobile-menu-toggle" class="site-header__mobile-btn" aria-label="Menu" title="Menu">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

    <a href="/" class="site-header__logo">KERN<span class="dot">.</span></a>

    <div class="site-header__search" id="search-wrap">
      <svg class="site-header__search-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input type="search" id="search-input" placeholder="Buscar posts..." autocomplete="off" aria-label="Buscar posts (Ctrl+K)" spellcheck="false" />
      <kbd class="site-header__search-shortcut">Ctrl K</kbd>
      <div class="search-results" id="search-results" role="listbox" aria-label="Resultados da busca" hidden></div>
    </div>

    <div class="site-header__actions">
      <a href="/fontes" class="site-header__action site-header__fontes">Fontes</a>
      <a href="/sobre" class="site-header__action site-header__sobre">Sobre</a>
      <div class="site-header__sep"></div>
      <a href="/rss.xml" class="site-header__action" title="RSS" aria-label="RSS Feed">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 11a9 9 0 0 1 9 9"></path>
          <path d="M4 4a16 16 0 0 1 16 16"></path>
          <circle cx="5" cy="19" r="1"></circle>
        </svg>
      </a>
      <a href="https://github.com/melloxyz/kern-ia" target="_blank" rel="noopener noreferrer" class="site-header__action" title="GitHub" aria-label="GitHub">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
      </a>
      <button id="theme-toggle" class="site-header__action theme-toggle-btn" title="Alternar tema" aria-label="Tema claro/escuro">
        <svg class="icon-moon-svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
        </svg>
        <svg class="icon-sun-svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </button>
    </div>

  </div>
</header>

<style>
/* ── HEADER ── */
.site-header {
  height: var(--header-h);
  border-bottom: 1px solid var(--border);
  background: var(--bg);
  position: sticky;
  top: 0;
  z-index: 100;
  transition:
    background 0.2s,
    border-color 0.2s;
}

.site-header__inner {
  max-width: var(--max);
  margin: 0 auto;
  padding: 0 24px;
  height: 100%;
  display: flex;
  align-items: center;
  gap: 20px;
}

.site-header__logo {
  font-family: var(--editorial);
  font-size: 28px;
  font-weight: 800;
  letter-spacing: -0.5px;
  white-space: nowrap;
  flex-shrink: 0;
  line-height: 1;
  color: var(--ink);
}
.site-header__logo .dot {
  color: var(--red);
  margin-left: 0.5px;
}
.site-header__logo:hover {
  color: var(--red);
}
.site-header__logo:hover .dot {
  color: var(--ink);
}
[data-theme="dark"] .site-header__logo:hover .dot {
  color: #fff;
}

/* Search */
.site-header__search {
  flex: 1;
  max-width: 320px;
  position: relative;
}
.site-header__search input {
  width: 100%;
  height: 36px;
  padding: 0 54px 0 34px;
  font-family: var(--mono);
  font-size: 14px;
  font-weight: 500;
  letter-spacing: 0;
  background: rgba(0, 0, 0, 0.05);
  border: 1px solid transparent;
  color: var(--ink);
  border-radius: 8px;
  outline: none;
  transition:
    border-color 0.15s,
    background 0.2s;
}
[data-theme="dark"] .site-header__search input {
  background: rgba(255, 255, 255, 0.1);
}
.site-header__search input::placeholder {
  color: var(--ink-light);
}
.site-header__search input:focus {
  background: #ffffff;
  border-color: var(--ink-light);
}
[data-theme="dark"] .site-header__search input:focus {
  background: var(--bg-card);
  border-color: var(--ink-light);
}
.site-header__search-icon {
  position: absolute;
  left: 12px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--ink-faint);
  pointer-events: none;
}
.site-header__search-shortcut {
  font-family: var(--mono);
  font-size: 10px;
  font-weight: 600;
  color: var(--ink-faint);
  background: var(--bg-card);
  border: 1px solid var(--border);
  padding: 2px 6px;
  border-radius: 4px;
  position: absolute;
  right: 12px;
  top: 50%;
  transform: translateY(-50%);
  pointer-events: none;
  letter-spacing: 0.5px;
}
.site-header__search
  input:not(:placeholder-shown)
  ~ .site-header__search-shortcut {
  opacity: 0;
}

/* Right actions */
.site-header__actions {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-left: auto;
  flex-shrink: 0;
}

.site-header__action {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  border-radius: 3px;
  color: var(--ink-light);
  background: none;
  border: none;
  cursor: pointer;
  transition:
    color 0.15s,
    background 0.15s;
  font-family: var(--mono);
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0;
  text-decoration: none;
  white-space: nowrap;
}
.site-header__action:hover {
  color: var(--ink);
  background: var(--bg-hover);
}

.site-header__sobre,
.site-header__fontes {
  width: auto;
  padding: 0 12px;
  font-size: 13px;
  font-family: var(--mono);
  font-weight: 600;
  letter-spacing: 0;
  text-transform: none;
}

.site-header__sep {
  width: 1px;
  height: 20px;
  background: var(--border);
  flex-shrink: 0;
  margin: 0 4px;
}

  /* ── SEARCH RESULTS (inline) ── */
  .search-results {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 3px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    z-index: 200;
    max-height: 320px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }
  .search-results::-webkit-scrollbar {
    width: 6px;
  }
  .search-results::-webkit-scrollbar-track {
    background: transparent;
  }
  .search-results::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 3px;
  }
  .search-results::-webkit-scrollbar-thumb:hover {
    background: var(--ink-light);
  }
  
  /* Estilos para elementos dinâmicos injetados via JS */
  .search-results :global(.search-results__item) {
    display: flex;
    flex-direction: column;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    transition: background 0.15s;
    text-decoration: none;
    gap: 4px;
  }
  .search-results :global(.search-results__item:last-child) {
    border-bottom: none;
  }
  .search-results :global(.search-results__item:hover),
  .search-results :global(.search-results__item--active) {
    background: var(--bg-hover);
  }

  .search-results :global(.search-results__top) {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 2px;
  }

  .search-results :global(.search-results__cat) {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 700;
    color: var(--red);
    letter-spacing: 0.5px;
    text-transform: uppercase;
    background: color-mix(in srgb, var(--red) 10%, transparent);
    padding: 2px 6px;
    border-radius: 4px;
  }

  .search-results :global(.search-results__cat--tag) {
    color: var(--ink);
    background: var(--bg-hover);
    border: 1px solid var(--border);
    padding: 1px 5px;
  }

  .search-results :global(.search-results__item--tag) {
    justify-content: center;
    min-height: 60px;
  }

  .search-results :global(.search-results__item--tag .search-results__title) {
    color: var(--red);
    font-size: 17px;
    font-weight: 700;
    margin-bottom: 0;
  }

  .search-results :global(.search-results__sep) {
    color: var(--ink-faint);
    font-size: 10px;
  }

  .search-results :global(.search-results__date) {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--ink-faint);
  }

  .search-results :global(.search-results__title) {
    font-family: var(--editorial);
    font-size: 15px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--ink);
  }

  .search-results :global(.search-results__excerpt) {
    font-family: var(--mono);
    font-size: 11px;
    line-height: 1.5;
    color: var(--ink-light);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .search-results :global(mark) {
    background: rgba(192, 57, 43, 0.12);
    color: var(--red);
    font-weight: 600;
    border-radius: 2px;
    padding: 0 2px;
  }

  .search-results :global(.search-results__empty) {
    padding: 16px 14px;
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--ink-faint);
  }

  @media (max-width: 680px) {
    .site-header__actions {
      display: none;
    }
  }
</style>

<script>
  function initHeader() {
    // Dark mode
    const html = document.documentElement;
    const toggleBtns = document.querySelectorAll('.theme-toggle-btn');
    const moonIcons = document.querySelectorAll('.icon-moon-svg');
    const sunIcons  = document.querySelectorAll('.icon-sun-svg');

    function applyTheme(dark: boolean) {
      html.setAttribute('data-theme', dark ? 'dark' : 'light');
      moonIcons.forEach(icon => (icon as HTMLElement).style.display = dark ? 'none' : 'block');
      sunIcons.forEach(icon => (icon as HTMLElement).style.display  = dark ? 'block' : 'none');
    }

    const stored = localStorage.getItem('theme');
    let isDark = stored === 'dark';
    applyTheme(isDark);

    toggleBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        isDark = !isDark;
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        applyTheme(isDark);
      });
    });

    // Search
    const searchWrap = document.getElementById('search-wrap');
    const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
    const searchResults = document.getElementById('search-results');
    let pagefind: any;
    let selectedIndex = -1;
    let currentHits: any[] = [];

    async function loadIndex() {
      if (pagefind) return;
      try {
        const pagefindUrl = `${window.location.origin}/pagefind/pagefind.js`;
        // @ts-ignore
        pagefind = await import(/* @vite-ignore */ pagefindUrl);
        await pagefind.options({ excerptLength: 15 });
      } catch (e) {
        console.warn('Pagefind só está disponível após o build (npm run build).', e);
      }
    }

    async function renderResults(query: string) {
      if (!searchResults) return;
      const trimmedQuery = query.trim();
      if (!trimmedQuery || !pagefind) { 
        searchResults.hidden = true; 
        currentHits = [];
        selectedIndex = -1;
        return; 
      }
      
      const search = await pagefind.search(trimmedQuery);
      const results = await Promise.all(search.results.slice(0, 6).map((r: any) => r.data()));
      
      currentHits = results;
      selectedIndex = -1;

      if (!currentHits.length) {
        searchResults.innerHTML = `<p class="search-results__empty">Nenhum resultado para "${query}"</p>`;
      } else {
        searchResults.innerHTML = currentHits.map((p, index) => {
          const isTag = p.url.startsWith('/tag/');
          const badgeText = isTag ? 'TAG' : (p.filters.category || 'Post');
          const badgeClass = isTag ? 'search-results__cat search-results__cat--tag' : 'search-results__cat';
          
          // Extrair apenas o horário/data caso venha no formato longo
          const dateStr = !isTag && p.meta.date ? p.meta.date.split('·')[1]?.trim() || p.meta.date : '';
          
          return `
            <a class="search-results__item ${isTag ? 'search-results__item--tag' : ''}" role="option" id="search-result-${index}" href="${p.url}">
              <div class="search-results__top">
                <span class="${badgeClass}">${badgeText}</span>
                ${dateStr ? `
                  <span class="search-results__sep">·</span>
                  <span class="search-results__date">${dateStr}</span>
                ` : ''}
              </div>
              <div class="search-results__title">${isTag ? '#' : ''}${p.meta.title}</div>
              ${!isTag ? `<div class="search-results__excerpt">${p.excerpt}</div>` : ''}
            </a>
          `;
        }).join('');
      }
      searchResults.hidden = false;
    }

    function updateSelection() {
      const items = searchResults?.querySelectorAll('.search-results__item');
      items?.forEach((item, idx) => {
        if (idx === selectedIndex) {
          item.classList.add('search-results__item--active');
          item.scrollIntoView({ block: 'nearest' });
        } else {
          item.classList.remove('search-results__item--active');
        }
      });
    }

    async function focusSearchFromShortcut() {
      await loadIndex();
      if (!searchInput) return;
      searchInput.focus();
      if (searchInput.value.trim()) {
        renderResults(searchInput.value);
      }
    }

    searchInput?.addEventListener('focus', loadIndex);
    searchInput?.addEventListener('input', (e) => {
      const target = e.target as HTMLInputElement | null;
      if (target) {
        renderResults(target.value);
      }
    });

    const handleOutsideClick = (e: MouseEvent) => {
      if (!searchWrap?.contains(e.target as Node)) {
        if (searchResults) searchResults.hidden = true;
      }
    };

    const handleKeydown = (e: KeyboardEvent) => {
      if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        focusSearchFromShortcut();
      }
      if (e.key === 'Escape' && searchResults && document.activeElement !== searchInput) {
        searchResults.hidden = true;
      }
    };

    document.addEventListener('click', handleOutsideClick);
    document.addEventListener('keydown', handleKeydown);

    searchInput?.addEventListener('keydown', e => {
      if (e.key === 'Escape' && searchResults) {
        searchResults.hidden = true;
        searchInput.blur();
      }
      if (!searchResults || searchResults.hidden) return;

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        selectedIndex = Math.min(selectedIndex + 1, currentHits.length - 1);
        updateSelection();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        selectedIndex = Math.max(selectedIndex - 1, -1);
        updateSelection();
      } else if (e.key === 'Enter' && selectedIndex >= 0) {
        e.preventDefault();
        const activeItem = searchResults.querySelector('.search-results__item--active') as HTMLAnchorElement;
        if (activeItem) activeItem.click();
      }
    });

    // Cleanup for View Transitions
    document.addEventListener('astro:before-preparation', () => {
      document.removeEventListener('click', handleOutsideClick);
      document.removeEventListener('keydown', handleKeydown);
    }, { once: true });
  }

  document.addEventListener('astro:page-load', initHeader);
</script>
