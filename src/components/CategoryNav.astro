---
import { 
  Cpu, 
  ShieldCheck, 
  CodeXml, 
  Briefcase, 
  TrendingUp, 
  Landmark, 
  SearchCode, 
  LayoutGrid 
} from '@lucide/astro';

interface Props {
  catLinks: Array<{
    href: string;
    label: string;
    icon: string;
    slug: string | null;
    count: number;
  }>;
  activeCatSlug: string | null;
}

const { catLinks, activeCatSlug } = Astro.props;

const iconMap: Record<string, any> = {
  Cpu,
  ShieldCheck,
  CodeXml,
  Briefcase,
  TrendingUp,
  Landmark,
  SearchCode,
  LayoutGrid
};
---
<nav class="page-layout__nav cat-nav" aria-label="Categorias">
  <p class="cat-nav__title">Categorias</p>
  <ul class="cat-nav__list">
    {catLinks.map(link => {
      const Icon = iconMap[link.icon];
      return (
        <li>
          <a
            href={link.href}
            class="cat-nav__link"
            aria-current={activeCatSlug === link.slug ? 'page' : (link.slug === null && !activeCatSlug ? 'page' : undefined)}
          >
            {Icon && <Icon size={16} strokeWidth={1.5} class="cat-nav__icon" />}
            <span class="cat-nav__label">{link.label}</span>
            {link.slug !== null && (
              <span class="cat-nav__count">{link.count}</span>
            )}
          </a>
        </li>
      );
    })}
  </ul>
</nav>

<style>
/* ── CATEGORY NAV (esquerda) ── */
.cat-nav {
  position: sticky;
  top: calc(var(--header-h) + 24px);
  padding: 24px 0;
}

.cat-nav__title {
  font-family: var(--mono);
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 0;
  color: var(--ink-light);
  text-transform: none;
  margin-bottom: 10px;
  padding-left: 2px;
}

.cat-nav__list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.cat-nav__link {
  display: flex;
  align-items: center;
  padding: 8px 10px;
  border-radius: 4px;
  font-family: var(--mono);
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0;
  color: var(--ink-light);
  transition:
    color 0.15s,
    background 0.15s;
  gap: 10px;
}
.cat-nav__link:hover {
  color: var(--ink);
  background: var(--bg-hover);
}
.cat-nav__link[aria-current="page"],
.cat-nav__link.active {
  color: var(--red);
  background: var(--bg-hover);
  font-weight: 700;
}

.cat-nav__icon {
  flex-shrink: 0;
  opacity: 0.7;
}
.cat-nav__link[aria-current="page"] .cat-nav__icon,
.cat-nav__link.active .cat-nav__icon {
  opacity: 1;
}

.cat-nav__label {
  flex-grow: 1;
}

.cat-nav__count {
  font-size: 11px;
  color: var(--ink-faint);
  font-weight: 500;
}

.cat-nav__sep {
  height: 1px;
  background: var(--border);
  margin: 8px 0;
}
</style>