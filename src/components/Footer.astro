---
import { CATEGORIES } from '../utils/posts';
---
<footer class="site-footer-wrap">
  <div class="site-footer">
    <div class="site-footer__top">
      <div class="site-footer__identity">
        <a href="/" class="site-footer__brand">KERN<span class="dot">.</span></a>
        <p class="site-footer__desc">Filtramos apenas o que importa de verdade!</p>
        <div class="site-footer__social">
          <a href="https://github.com/melloxyz/kern-ia" target="_blank" rel="noopener noreferrer" aria-label="GitHub">GitHub</a>
          <span class="sep">/</span>
          <a href="/rss.xml">RSS</a>
        </div>
      </div>
      
      <div class="site-footer__navs">
        <nav class="site-footer__col" aria-label="Explorar">
          <span class="site-footer__col-title">Explorar</span>
          {CATEGORIES.slice(0, 4).map((c) => (
            <a href={`/${c.slug}`}>{c.label}</a>
          ))}
        </nav>
        <nav class="site-footer__col" aria-label="Conteúdo">
          <span class="site-footer__col-title">Conteúdo</span>
          <a href="/sobre">Sobre o projeto</a>
          <a href="/privacidade">Privacidade</a>
          <a href="/arquivo/2026/04">Arquivo recente</a>
          <a href="/rss.xml">Feed RSS</a>
        </nav>
      </div>
    </div>
    
    <div class="site-footer__bottom">
      <span class="site-footer__copy">© {new Date().getFullYear()} KERN. Todos os direitos reservados.</span>
      <span class="site-footer__tagline">Sinal acima do ruído.</span>
    </div>
  </div>
</footer>
