---
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'posts'>[];
}

const { posts } = Astro.props;

function formatDate(date: Date) {
  const time = date.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
  const day = date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' });
  return `${time} · ${day}`;
}
---

{posts.length > 0 && (
  <section class="related-posts">
    <h3 class="related-posts__title">Leia a seguir</h3>
    <div class="related-posts__grid">
      {posts.map(post => (
        <a href={`/posts/${post.id}`} class="related-card">
          <div class="related-card__content">
            <span class="related-card__category">{post.data.category}</span>
            <h4 class="related-card__title">{post.data.title}</h4>
            <span class="related-card__date">{formatDate(post.data.date)}</span>
          </div>
        </a>
      ))}
    </div>
  </section>
)}
