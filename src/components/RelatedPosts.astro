---
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'posts'>[];
}

const { posts } = Astro.props;

function formatDate(date: Date) {
  const time = date.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
  const day = date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' });
  return `${time} · ${day}`;
}
---

{posts.length > 0 && (
  <section class="related-posts">
    <h3 class="related-posts__title">Leia a seguir</h3>
    <div class="related-posts__grid">
      {posts.map(post => (
        <a href={`/posts/${post.id}`} class="related-card">
          <div class="related-card__content">
            <span class="related-card__category">{post.data.category}</span>
            <h4 class="related-card__title">{post.data.title}</h4>
            <span class="related-card__date">{formatDate(post.data.date)}</span>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<style>
/* ── RELATED POSTS ── */
.related-posts {
  margin-top: 80px;
  padding-top: 40px;
  border-top: 2px solid var(--border-dark);
}
.related-posts__title {
  font-family: var(--mono);
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--ink-light);
  margin-bottom: 24px;
}
.related-posts__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}
.related-card {
  display: block;
  background: var(--bg-card);
  border: 1px solid var(--border);
  transition: all 0.2s ease;
  height: 100%;
}
.related-card:hover {
  border-color: var(--red);
  transform: translateY(-4px);
  box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
}
.related-card__content {
  padding: 24px;
  display: flex;
  flex-direction: column;
}
.related-card__category {
  font-family: var(--mono);
  font-size: 10px;
  font-weight: 700;
  color: var(--red);
  background: color-mix(in srgb, var(--red) 12%, transparent);
  padding: 4px 6px;
  border-radius: 4px;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 8px;
  display: inline-block;
  align-self: flex-start;
}
.related-card__title {
  font-family: var(--editorial);
  font-size: 1.25rem;
  line-height: 1.3;
  margin-bottom: 12px;
  color: var(--ink);
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.related-card__date {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--ink-faint);
}
</style>
