    <button class="share__btn share__btn-copy" id="copy-btn" title="Copiar link" data-url={url}>
      <svg id="icon-copy" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
      </svg>
      <svg id="icon-check" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none; color: #10b981;">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
    </button>
  </div>
  </div>
</div>

<script>
  const copyBtn = document.getElementById('copy-btn');
  const iconCopy = document.getElementById('icon-copy');
  const iconCheck = document.getElementById('icon-check');
  let isCopying = false;

  copyBtn?.addEventListener('click', async () => {
    if (isCopying) return;
    
    const url = copyBtn.getAttribute('data-url');
    if (!url) return;

    try {
      await navigator.clipboard.writeText(url);
      isCopying = true;

      if (iconCopy) iconCopy.style.display = 'none';
      if (iconCheck) iconCheck.style.display = 'block';

      setTimeout(() => {
        if (iconCopy) iconCopy.style.display = 'block';
        if (iconCheck) iconCheck.style.display = 'none';
        isCopying = false;
      }, 2000);
    } catch (err) {
      console.error('Falha ao copiar:', err);
    }
  });
</script>
