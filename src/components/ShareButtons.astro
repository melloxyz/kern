---
interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;
const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(url);

// Mensagem organizada para redes de texto (WhatsApp, Telegram, Bluesky)
const shareText = `Veja esta análise no KERN: "${title}" — ${url}`;
const encodedShareText = encodeURIComponent(shareText);

const shareLinks = {
  twitter: `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`,
  bluesky: `https://bsky.app/intent/compose?text=${encodedShareText}`,
  threads: `https://www.threads.net/intent/post?text=${encodedShareText}`,
  linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`,
  whatsapp: `https://api.whatsapp.com/send?text=${encodedShareText}`,
  telegram: `https://t.me/share/url?url=${encodedUrl}&text=${encodedTitle}`,
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`
};
---

<div class="share">
  <span class="share__label">Gostou? Compartilhe:</span>
  <div class="share__buttons">
    <a href={shareLinks.twitter} target="_blank" rel="noopener noreferrer" class="share__btn" title="Compartilhar no X">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
