---
import '../styles/global.css';
import { getCollection } from 'astro:content';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'KERN.IA',
  description = 'Inteligência artificial sem enrolação.',
} = Astro.props;

const fullTitle = title === 'KERN.IA' ? title : `${title} — KERN.IA`;
const currentPath = Astro.url.pathname;
const normalizedPath = currentPath.length > 1 && currentPath.endsWith('/')
  ? currentPath.slice(0, -1)
  : currentPath;

const allPosts = await getCollection('posts', ({ data }) => !data.draft);

const CATEGORIES = [
  { slug: 'modelos', category: 'MODELOS', label: 'Modelos' },
  { slug: 'seguranca', category: 'SEGURANÇA', label: 'Segurança' },
  { slug: 'open-source', category: 'OPEN SOURCE', label: 'Open Source' },
  { slug: 'trabalho', category: 'TRABALHO', label: 'Trabalho' },
  { slug: 'negocios', category: 'NEGÓCIOS', label: 'Negócios' },
  { slug: 'politica', category: 'POLÍTICA', label: 'Política' },
  { slug: 'pesquisa', category: 'PESQUISA', label: 'Pesquisa' },
];

let activeCatSlug = null;
let activeYear = null;
let activeMonth = null;

const archiveMatch = normalizedPath.match(/^\/arquivo\/(\d{4})\/(\d{2})(?:\/([^/]+))?$/);
if (archiveMatch) {
  activeYear = archiveMatch[1];
  activeMonth = archiveMatch[2];
  if (archiveMatch[3]) {
    activeCatSlug = archiveMatch[3];
  }
} else {
  const catMatch = normalizedPath.match(/^\/([^/]+)$/);
  if (catMatch && CATEGORIES.some(c => c.slug === catMatch[1])) {
    activeCatSlug = catMatch[1];
  }
}

const catCounts = {};
for (const cat of CATEGORIES) catCounts[cat.category] = 0;
let totalPostsInContext = 0;

for (const post of allPosts) {
  const postYear = String(post.data.date.getFullYear());
  const postMonth = String(post.data.date.getMonth() + 1).padStart(2, '0');
  
  if (activeYear && activeMonth) {
    if (postYear === activeYear && postMonth === activeMonth) {
      if (catCounts[post.data.category] !== undefined) catCounts[post.data.category]++;
      totalPostsInContext++;
    }
  } else {
    if (catCounts[post.data.category] !== undefined) catCounts[post.data.category]++;
    totalPostsInContext++;
  }
}

const catLinks = [
  { 
    href: (activeYear && activeMonth) ? `/arquivo/${activeYear}/${activeMonth}` : '/', 
    label: 'Todos', 
    cat: null,
    slug: null,
    count: totalPostsInContext
  },
  ...CATEGORIES.map(c => ({
    href: (activeYear && activeMonth) ? `/arquivo/${activeYear}/${activeMonth}/${c.slug}` : `/${c.slug}`,
    label: c.label,
    cat: c.category,
    slug: c.slug,
    count: catCounts[c.category]
  }))
];

const MONTHS_PT = ['Janeiro','Fevereiro','Março','Abril','Maio','Junho',
                   'Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];

const archiveMap = new Map();

for (const post of [...allPosts].sort((a, b) => b.data.date.getTime() - a.data.date.getTime())) {
  if (activeCatSlug) {
    const catObj = CATEGORIES.find(c => c.slug === activeCatSlug);
    if (catObj && post.data.category !== catObj.category) {
      continue;
    }
  }

  const y = String(post.data.date.getFullYear());
  const m = String(post.data.date.getMonth() + 1).padStart(2, '0');
  const key = `${y}-${m}`;
  
  if (!archiveMap.has(key)) {
    archiveMap.set(key, {
      label: `${MONTHS_PT[Number(m) - 1]} ${y}`,
      year: y, month: m, count: 0,
      href: activeCatSlug ? `/arquivo/${y}/${m}/${activeCatSlug}` : `/arquivo/${y}/${m}`,
      key
    });
  }
  archiveMap.get(key).count++;
}

const activeArchiveKey = (activeYear && activeMonth) ? `${activeYear}-${activeMonth}` : undefined;
const archive = [...archiveMap.values()].filter(entry => (
  activeYear ? entry.year === activeYear : true
));
---

<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{fullTitle}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:wght@400;700&display=swap" rel="stylesheet" />
</head>
<body>

  <header class="site-header">
    <div class="site-header__inner">

      <a href="/" class="site-header__logo">KERN<span>.IA</span></a>

      <div class="site-header__search" id="search-wrap">
        <svg class="site-header__search-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input type="search" id="search-input" placeholder="Buscar posts..." autocomplete="off" aria-label="Buscar posts (Ctrl+K)" spellcheck="false" />
        <kbd class="site-header__search-shortcut">Ctrl K</kbd>
        <div class="search-results" id="search-results" role="listbox" aria-label="Resultados da busca" hidden></div>
      </div>

      <div class="site-header__actions">
        <a href="/sobre" class="site-header__action site-header__sobre">Sobre</a>
        <div class="site-header__sep"></div>
        <a href="/rss.xml" class="site-header__action" title="RSS" aria-label="RSS Feed">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 11a9 9 0 0 1 9 9"></path>
            <path d="M4 4a16 16 0 0 1 16 16"></path>
            <circle cx="5" cy="19" r="1"></circle>
          </svg>
        </a>
        <a href="https://github.com/melloxyz/kern-ia" target="_blank" rel="noopener" class="site-header__action" title="GitHub" aria-label="GitHub">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
        </a>
        <button id="theme-toggle" class="site-header__action" title="Alternar tema" aria-label="Tema claro/escuro">
          <svg id="icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
          </svg>
          <svg id="icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
        </button>
      </div>

    </div>
  </header>

  <div class="page-layout">

    <nav class="page-layout__nav cat-nav" aria-label="Categorias">
      <p class="cat-nav__title">Categorias</p>
      <ul class="cat-nav__list">
        {catLinks.map(link => (
          <li>
            <a
              href={link.href}
              class="cat-nav__link"
              aria-current={activeCatSlug === link.slug ? 'page' : (link.slug === null && !activeCatSlug ? 'page' : undefined)}
            >
              <span class="cat-nav__dot"></span>
              {link.label}
              {link.slug !== null && (
                <span class="cat-nav__count">{link.count}</span>
              )}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <main class="page-layout__main">
      <slot />
    </main>

    <aside class="page-layout__archive">
      <nav class="archive" aria-label="Arquivo por mês">
        <p class="archive__title">TIMELINE</p>
        <ul class="archive__list">
          {archive.map(entry => {
            const key = `${entry.year}-${String(entry.month).padStart(2,'0')}`;
            return (
              <li class={`archive__item ${activeArchiveKey === key ? 'archive__item--active' : ''}`}>
                <a href={entry.href}>
                  <span>{entry.label}</span>
                  <span class="archive__count">{entry.count}</span>
                </a>
              </li>
            );
          })}
        </ul>
      </nav>
    </aside>

  </div>

  <footer class="site-footer-wrap">
    <div class="site-footer">
      <div class="site-footer__top">
        <div class="site-footer__identity">
          <a href="/" class="site-footer__brand">KERN<span>.IA</span></a>
          <p class="site-footer__desc">Inteligência artificial sem hype vazio. Foco em produto, mercado, segurança e trabalho.</p>
        </div>
        
        <div class="site-footer__navs">
          <nav class="site-footer__col" aria-label="Projeto">
            <span class="site-footer__col-title">Projeto</span>
            <a href="/sobre">Sobre o KERN.IA</a>
            <a href="/rss.xml">Feed RSS</a>
            <a href="https://github.com/melloxyz/kern-ia" target="_blank" rel="noopener">GitHub / Open-Source</a>
          </nav>
          <nav class="site-footer__col" aria-label="Categorias em Destaque">
            <span class="site-footer__col-title">Tópicos</span>
            {CATEGORIES.slice(0, 4).map(c => <a href={`/${c.slug}`}>{c.label}</a>)}
          </nav>
        </div>
      </div>
      
      <div class="site-footer__bottom">
        <span class="site-footer__copy">© {new Date().getFullYear()} KERN.IA. Construído com Astro.</span>
        <span class="site-footer__tagline">sem ads · sem paywalls</span>
      </div>
    </div>
  </footer>

  <button id="back-to-top" class="back-to-top" aria-label="Voltar ao topo" title="Voltar ao topo">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M18 15l-6-6-6 6"/>
    </svg>
  </button>

  <script>
    // Dark mode
    const html = document.documentElement;
    const btn  = document.getElementById('theme-toggle');
    const moon = document.getElementById('icon-moon');
    const sun  = document.getElementById('icon-sun');

    function applyTheme(dark) {
      html.setAttribute('data-theme', dark ? 'dark' : 'light');
      if (moon) moon.style.display = dark ? 'none' : 'block';
      if (sun)  sun.style.display  = dark ? 'block' : 'none';
    }

    const stored = localStorage.getItem('theme');
    let isDark = stored === 'dark';
    applyTheme(isDark);

    btn?.addEventListener('click', () => {
      isDark = !isDark;
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      applyTheme(isDark);
    });

    // Search
    const searchWrap = document.getElementById('search-wrap');
    const searchInput   = document.getElementById('search-input');
    const searchResults = document.getElementById('search-results');
    let postIndex = [];

    async function loadIndex() {
      if (postIndex.length) return;
      try {
        const res = await fetch('/search-index.json');
        if (res.ok) postIndex = await res.json();
      } catch {}
    }

    function normalize(str) {
      return str.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase();
    }

    function renderResults(query) {
      if (!searchResults) return;
      if (!query.trim()) { searchResults.hidden = true; return; }
      const q = normalize(query);
      const hits = postIndex.filter(p =>
        normalize(p.title).includes(q) || normalize(p.excerpt).includes(q)
      ).slice(0, 6);
      if (!hits.length) {
        searchResults.innerHTML = `<p class="search-results__empty">Nenhum resultado para "${query}"</p>`;
      } else {
        searchResults.innerHTML = hits.map((p, index) => `
          <a class="search-results__item" role="option" id="search-result-${index}" href="/posts/${p.slug}">
            <div class="search-results__cat">${p.category}</div>
            <div class="search-results__title">${p.title}</div>
          </a>
        `).join('');
      }
      searchResults.hidden = false;
    }

    async function focusSearchFromShortcut() {
      await loadIndex();
      if (!searchInput) return;
      searchInput.focus();
      if (searchInput.value.trim()) {
        renderResults(searchInput.value);
      }
    }

    searchInput?.addEventListener('focus', loadIndex);
    searchInput?.addEventListener('input', e => renderResults(e.target.value));
    document.addEventListener('click', e => {
      if (!searchWrap?.contains(e.target)) {
        if (searchResults) searchResults.hidden = true;
      }
    });
    document.addEventListener('keydown', e => {
      if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        focusSearchFromShortcut();
      }
      if (e.key === 'Escape' && searchResults && document.activeElement !== searchInput) {
        searchResults.hidden = true;
      }
    });
    searchInput?.addEventListener('keydown', e => {
      if (e.key === 'Escape' && searchResults) {
        searchResults.hidden = true;
        searchInput.blur();
      }
    });

    // Back to top
    const backToTopBtn = document.getElementById('back-to-top');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 400) {
        backToTopBtn?.classList.add('show');
      } else {
        backToTopBtn?.classList.remove('show');
      }
    });
    backToTopBtn?.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  </script>

</body>
</html>
