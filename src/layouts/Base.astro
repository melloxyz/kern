---
import '../styles/global.css';
import { getCollection } from 'astro:content';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'RuídoIA', description = 'Inteligência artificial sem enrolação.' } = Astro.props;
const fullTitle = title === 'RuídoIA' ? title : `${title} — RuídoIA`;

const today = new Date().toLocaleDateString('pt-BR', {
  weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'
});

const navLinks = [
  { href: '/',            label: 'Feed' },
  { href: '/modelos',     label: 'Modelos' },
  { href: '/seguranca',   label: 'Segurança' },
  { href: '/trabalho',    label: 'Trabalho' },
  { href: '/negocios',    label: 'Negócios' },
  { href: '/politica',    label: 'Política' },
  { href: '/sobre',       label: 'Sobre' },
];

const currentPath = Astro.url.pathname;

// Build global archive (months) so "Nesta página" can live in the layout
const allPostsForArchive = await getCollection('posts', ({ data }) => !data.draft);

const MONTHS_PT = ['Janeiro','Fevereiro','Março','Abril','Maio','Junho',
                   'Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];

const archiveMap = new Map();
for (const post of allPostsForArchive) {
  const y = post.data.date.getFullYear();
  const m = post.data.date.getMonth();
  const key = `${y}-${String(m).padStart(2,'0')}`;
  if (!archiveMap.has(key)) {
    archiveMap.set(key, {
      label: `${MONTHS_PT[m]} ${y}`,
      year: y,
      month: m + 1,
      count: 0,
      href: `/arquivo/${y}/${String(m+1).padStart(2,'0')}`,
    });
  }
  archiveMap.get(key).count++;
}
const archive = [...archiveMap.values()];

const pathMatch = Astro.url.pathname.match(/^\/arquivo\/(\d{4})\/(\d{2})/);
const activeKey = pathMatch ? `${pathMatch[1]}-${pathMatch[2]}` : undefined;
---

<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{fullTitle}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
</head>
<body>

  <header class="site-header">
    <div class="container">
      <div class="site-header__top">
        <span>{today}</span>
        <span>sem ads · sem paywalls · só texto</span>
      </div>
      <div class="site-header__brand">
        <a href="/">
          <h1 class="site-header__logo">RUÍDO<span>IA</span></h1>
        </a>
        <p class="site-header__tagline">inteligência artificial sem enrolação</p>
      </div>
    </div>
  </header>

  <nav class="site-nav">
    <div class="container">
      <ul class="site-nav__list">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class="site-nav__link"
              aria-current={currentPath === link.href ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <aside class="archive archive--floating">
    <nav>
      <p class="archive__title">Nesta página</p>
      <ul class="archive__list">
        {archive.map(entry => (
          <li class={`archive__item ${activeKey === `${entry.year}-${String(entry.month).padStart(2,'0')}` ? 'archive__item--active' : ''}`}>
            <a href={entry.href}>
              {entry.label}
              <span class="archive__count">{entry.count}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </aside>

  <script>
    (function () {
      function updateArchiveTop() {
        const nav = document.querySelector('.site-nav');
        const archive = document.querySelector('.archive--floating');
        if (!nav || !archive) return;
        const navRect = nav.getBoundingClientRect();
        const top = Math.max(navRect.bottom, 0) + 8;
        archive.style.top = `${top}px`;
      }
      if (typeof window !== 'undefined') {
        window.addEventListener('load', updateArchiveTop);
        window.addEventListener('resize', updateArchiveTop);
        window.addEventListener('scroll', updateArchiveTop, { passive: true });
        requestAnimationFrame(updateArchiveTop);
      }
    })();
  </script>

  <footer>
    <div class="container">
      <div class="site-footer">
        <span class="site-footer__brand">RUÍDO<span>IA</span></span>
        <span class="site-footer__copy">feito com texto · sem distrações · © {new Date().getFullYear()}</span>
      </div>
    </div>
  </footer>

</body>
</html>
